# SMS Provider Configuration
# Choose ONE provider and configure its credentials

# Option 1: Twilio (International)
# VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_TWILIO_AUTH_TOKEN=your_auth_token_here
# VITE_TWILIO_PHONE_NUMBER=+1234567890

# Option 2: MSG91 (India - Recommended)
# VITE_MSG91_API_KEY=your_api_key_here
# VITE_MSG91_TEMPLATE_ID=your_template_id_here

# Option 3: Fast2SMS (India)
# VITE_FAST2SMS_API_KEY=your_api_key_here

# Option 4: Generic SMS API
# VITE_SMS_API_URL=https://api.smsgateway.com/send
# VITE_SMS_API_KEY=your_api_key_here

# Note: If no provider is configured, system runs in DEMO MODE
# Demo mode displays OTP in browser alert (perfect for testing)
